<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Transpersonal Training</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Merriweather', 'serif'],
                    },
                    animation: {
                        'fade-in-up': 'fadeInUp 1s ease-out forwards',
                    },
                    keyframes: {
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    
    <link rel="stylesheet" href="/style.css">
</head>
<body class="font-sans text-slate-800 bg-slate-50 antialiased">

    <!-- Navigation -->
    {% include "navigation.njk" %}

    <!-- Main Content -->
    <main>
        {{ content | safe }}
    </main>

    <!-- Footer -->
    {% include "footer.njk" %}

    <!-- Fixed Theme Switcher Button -->
    <div id="theme-switcher-fixed">
        <div class="theme-label" id="theme-label">School Lavender</div>
        <button id="theme-btn-fixed" title="Switch theme" aria-label="Switch color theme">
            <i data-lucide="palette" class="w-6 h-6 text-white"></i>
        </button>
    </div>

    <!-- Theme switcher script -->
    <script src="/theme-switcher.js"></script>
    <script src="/script.js"></script>

    {% block scripts %}{% endblock %}
</body>
</html>
