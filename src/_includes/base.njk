<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Transpersonal Training</title>

    {# SEO Meta Tags #}
    {% if description %}
    <meta name="description" content="{{ description }}">
    {% endif %}
    <link rel="canonical" href="https://transpersonal-training.com{{ page.url }}">

    {# Open Graph / Facebook #}
    <meta property="og:type" content="{{ ogType if ogType else 'website' }}">
    <meta property="og:url" content="https://transpersonal-training.com{{ page.url }}">
    <meta property="og:title" content="{{ title }} | Transpersonal Training">
    {% if description %}
    <meta property="og:description" content="{{ description }}">
    {% endif %}
    <meta property="og:site_name" content="Transpersonal Training">
    <meta property="og:locale" content="en_GB">
    <meta property="og:image" content="https://transpersonal-training.com{{ '/assets/images/og-default.jpg' | url }}">

    {# Twitter Card #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} | Transpersonal Training">
    {% if description %}
    <meta name="twitter:description" content="{{ description }}">
    {% endif %}
    <meta name="twitter:image" content="https://transpersonal-training.com{{ '/assets/images/og-default.jpg' | url }}">

    {# JSON-LD Structured Data #}
    {% if page.url == "/" %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "Transpersonal Training",
      "url": "https://transpersonal-training.com",
      "description": "Professional transpersonal psychotherapy and breathwork training. EUROTAS-accredited online programme with in-person intensives in Western Europe.",
      "email": "info@transpersonal-training.com",
      "sameAs": [],
      "hasCredential": {
        "@type": "EducationalOccupationalCredential",
        "credentialCategory": "Professional Certification",
        "recognizedBy": {
          "@type": "Organization",
          "name": "EUROTAS"
        }
      }
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "Transpersonal Counselling & Breathwork Psychotherapy Training",
      "description": "A 4-year professional training in transpersonal psychotherapy integrating developmental, relational and archetypal perspectives.",
      "provider": {
        "@type": "EducationalOrganization",
        "name": "Transpersonal Training",
        "url": "https://transpersonal-training.com"
      },
      "educationalLevel": "Professional",
      "timeRequired": "P4Y",
      "occupationalCategory": "Transpersonal Psychotherapist",
      "teaches": ["Transpersonal Psychology", "Holotropic Breathwork", "Counselling Skills", "Psychotherapy"],
      "availableLanguage": "English",
      "courseMode": ["Online", "Blended"],
      "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": "Blended",
        "startDate": "2024",
        "endDate": "2027"
      }
    }
    </script>
    {% endif %}
    
    <!-- Page Loader Styles (inline for immediate display) -->
    <style>
        #page-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.3s ease-out;
        }
        
        #page-loader.hidden {
            opacity: 0;
            pointer-events: none;
        }
        
        .loader-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(102, 126, 234, 0.2);
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        .loader-text {
            color: #334155;
            font-size: 1.125rem;
            font-weight: 500;
            margin-top: 1.5rem;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
    
    <!-- Stylesheets (load first for faster rendering) -->
    <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
    <link rel="stylesheet" href="{{ '/style.css' | url }}">
        <link rel="icon" type="image/svg+xml" href="{{ '/assets/images/logo.svg' | url }}">
        <link rel="shortcut icon" type="image/svg+xml" href="{{ '/assets/images/logo.svg' | url }}">
    
    <!-- Fonts (preconnect and async load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet"></noscript>
    
    <!-- Lucide Icons (defer loading) -->
    <script src="https://unpkg.com/lucide@0.344.0" defer></script>
</head>
<body class="font-sans text-slate-800 bg-slate-50 antialiased">

    <!-- Page Loader -->
    <div id="page-loader">
        <div class="loader-spinner"></div>
        <div class="loader-text">Loading...</div>
    </div>

    <!-- Navigation -->
    {% include "navigation.njk" %}

    <!-- Main Content -->
    <main>
        {{ content | safe }}
    </main>

    <!-- Footer -->
    {% include "footer.njk" %}

    <!-- Main application script -->
    <script type="module" src="{{ '/scripts/main.js' | url }}"></script>

    {% block scripts %}{% endblock %}
    
    <!-- Remove loader when page is fully loaded -->
    <script>
        window.addEventListener('load', function() {
            const loader = document.getElementById('page-loader');
            if (loader) {
                loader.classList.add('hidden');
                setTimeout(() => loader.remove(), 300);
            }
        });
    </script>
</body>
</html>
