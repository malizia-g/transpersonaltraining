<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Transpersonal Training</title>
    
    <!-- Page Loader Styles (inline for immediate display) -->
    <style>
        #page-loader {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            transition: opacity 0.3s ease-out;
        }
        
        #page-loader.hidden {
            opacity: 0;
            pointer-events: none;
        }
        
        .loader-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(102, 126, 234, 0.2);
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        .loader-text {
            color: #334155;
            font-size: 1.125rem;
            font-weight: 500;
            margin-top: 1.5rem;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
    
    <!-- Stylesheets (load first for faster rendering) -->
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/style.css">
    
    <!-- Fonts (preconnect and async load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&display=swap" rel="stylesheet"></noscript>
    
    <!-- Lucide Icons (defer loading) -->
    <script src="https://unpkg.com/lucide@latest" defer></script>
    
    <!-- Netlify Identity Widget (for CMS authentication) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body class="font-sans text-slate-800 bg-slate-50 antialiased">

    <!-- Page Loader -->
    <div id="page-loader">
        <div class="loader-spinner"></div>
        <div class="loader-text">Loading...</div>
    </div>

    <!-- Navigation -->
    {% include "navigation.njk" %}

    <!-- Main Content -->
    <main>
        {{ content | safe }}
    </main>

    <!-- Footer -->
    {% include "footer.njk" %}

    <!-- Fixed Theme Switcher Button -->
    <div id="theme-switcher-fixed">
        <div class="theme-label" id="theme-label">School Lavender</div>
        <button id="theme-btn-fixed" title="Switch theme" aria-label="Switch color theme">
            <i data-lucide="palette" class="w-6 h-6 text-white"></i>
        </button>
    </div>

    <!-- Main application script -->
    <script type="module" src="/scripts/main.js"></script>

    {% block scripts %}{% endblock %}
    
    <!-- Remove loader when page is fully loaded -->
    <script>
        window.addEventListener('load', function() {
            const loader = document.getElementById('page-loader');
            if (loader) {
                loader.classList.add('hidden');
                setTimeout(() => loader.remove(), 300);
            }
        });
    </script>
    
    <!-- Netlify Identity redirect -->
    <script>
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on("init", user => {
                if (!user) {
                    window.netlifyIdentity.on("login", () => {
                        document.location.href = "/admin/";
                    });
                }
            });
        }
    </script>
</body>
</html>
